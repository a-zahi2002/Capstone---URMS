PORT=5000
NODE_ENV=development

# ─── Supabase (PostgreSQL) ───────────────────────────────────
# Replace with your actual Supabase project URL and anon key.
# Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ─── Firebase Admin SDK ──────────────────────────────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY="your-private-key"

# ─── Watchdog ────────────────────────────────────────────────
# Optional: Command to restart DB service if a crash is detected
# Example (Windows): net start MySQL
# Example (Docker): docker restart supabase-db
DB_RESTART_COMMAND=

# ─── Supabase Direct PostgreSQL Connection (SSL) ─────────────
# Use this if connecting to Supabase via a direct PG client
# (e.g., Prisma, Drizzle, knex, node-postgres).
#
# • sslmode=require   → encrypts the connection, trusts the server cert
# • sslmode=verify-full → encrypts AND verifies the server CA (most secure)
#
# Find your connection string: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
